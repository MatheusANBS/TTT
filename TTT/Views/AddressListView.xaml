<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TTT.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="TTT.Views.AddressListView"
             x:DataType="vm:AddressListViewModel"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="820">

    <UserControl.Styles>
        <Style Selector="Border.page-card">
            <Setter Property="Background" Value="#151B22" />
            <Setter Property="BorderBrush" Value="#2B3844" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Border.group-header-card">
            <Setter Property="Background" Value="#1A2430" />
            <Setter Property="BorderBrush" Value="#304152" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.group-header-card.expanded">
            <Setter Property="CornerRadius" Value="10,10,0,0" />
            <Setter Property="BorderThickness" Value="1,1,1,0" />
        </Style>

        <Style Selector="Border.group-header-card.freeze-active">
            <Setter Property="Background" Value="#1E3140" />
            <Setter Property="BorderBrush" Value="#4FA3D8" />
        </Style>

        <Style Selector="Border.group-body-card">
            <Setter Property="Background" Value="#151B22" />
            <Setter Property="BorderBrush" Value="#2F3942" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="Border.group-body-card.expanded">
            <Setter Property="BorderThickness" Value="1,0,1,1" />
            <Setter Property="CornerRadius" Value="0,0,10,10" />
        </Style>

        <Style Selector="Border.group-body-card.freeze-active">
            <Setter Property="BorderBrush" Value="#4FA3D8" />
        </Style>

        <Style Selector="Button.toolbar-primary">
            <Setter Property="Background" Value="#245B9E" />
            <Setter Property="BorderBrush" Value="#3A79C4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.toolbar-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2F6AB0" />
        </Style>

        <Style Selector="Button.toolbar-secondary">
            <Setter Property="Background" Value="#202A34" />
            <Setter Property="BorderBrush" Value="#3A4A59" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF5" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.toolbar-secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3642" />
        </Style>

        <Style Selector="Button.group-action">
            <Setter Property="Background" Value="#1F2A34" />
            <Setter Property="BorderBrush" Value="#3B4D5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#DCE6F2" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.group-action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#273442" />
        </Style>

        <Style Selector="Button.group-danger">
            <Setter Property="Background" Value="#3B2026" />
            <Setter Property="BorderBrush" Value="#7A3A47" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFD7DE" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Button.group-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#512B33" />
        </Style>

        <Style Selector="ToggleButton.group-expander-chevron">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#23303D" />
            <Setter Property="BorderBrush" Value="#334758" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="ChevronSurface"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.group-expander-chevron:pointerover /template/ Border#ChevronSurface">
            <Setter Property="Background" Value="#2A3948" />
        </Style>

        <Style Selector="ToggleButton.group-expander-chevron:checked /template/ Border#ChevronSurface">
            <Setter Property="Background" Value="#2C5675" />
            <Setter Property="BorderBrush" Value="#4FA3D8" />
        </Style>

        <Style Selector="PathIcon.expander-chevron">
            <Setter Property="Data" Value="M8.59,16.59L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.59Z" />
        </Style>

        <Style Selector="ToggleButton.group-expander-chevron:checked PathIcon.expander-chevron">
            <Setter Property="Data" Value="M7.41,8.59L12,13.17L16.59,8.59L18,10L12,16L6,10L7.41,8.59Z" />
        </Style>

        <Style Selector="DataGrid.group-grid">
            <Setter Property="Background" Value="#151B22" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="#151B22" />
            <Setter Property="HorizontalGridLinesBrush" Value="#253543" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        </Style>

        <Style Selector="DataGrid.group-grid DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2430" />
            <Setter Property="Foreground" Value="#E7F0FA" />
            <Setter Property="BorderBrush" Value="#2D3F50" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="DataGrid.group-grid DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#253543" />
        </Style>

        <Style Selector="DataGrid.group-grid DataGridRow:pointerover">
            <Setter Property="Background" Value="#1B2631" />
        </Style>

        <Style Selector="DataGrid.group-grid DataGridRow:selected">
            <Setter Property="Background" Value="#1D5F96" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="18" RowDefinitions="Auto,*">
        <Border Grid.Row="0" Classes="page-card" Padding="18">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="Address Manager"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#EDF3FA" />
                    <TextBlock Text="Gerencie valores em tempo real com organização por grupos e ações em lote."
                               Opacity="0.8"
                               Foreground="#CBDAEA" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Classes="toolbar-secondary"
                            Content="Atualizar"
                            Command="{Binding RefreshValuesCommand}" />
                    <Button Classes="toolbar-primary"
                            Content="Adicionar Entrada"
                            Command="{Binding AddEntryCommand}" />
                    <Button Classes="toolbar-secondary"
                            Content="Novo Grupo"
                            Command="{Binding CreateGroupCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                  Margin="0,14,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding GroupedAddressList}">
                <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                        <StackPanel Margin="0,0,0,10"
                                Spacing="0">
                            <Border Classes="group-header-card"
                                Classes.freeze-active="{Binding HasFrozenEntries}"
                                    Classes.expanded="{Binding IsExpanded}"
                                    Padding="12,10">
                                <Grid
                                  ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12"
                                  HorizontalAlignment="Stretch">
                                <ToggleButton Grid.Column="0"
                                      Classes="group-expander-chevron"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                      VerticalAlignment="Center">
                                <PathIcon Classes="expander-chevron"
                                      Width="12"
                                      Height="12"
                                      Foreground="#D7E4F1" />
                                </ToggleButton>

                                <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                                <Border Width="10"
                                    Height="10"
                                    CornerRadius="20"
                                    VerticalAlignment="Center"
                                    Background="#5B89C5" />
                                <TextBlock Text="{Binding Name}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#EDF4FC" />
                                <TextBlock Text="Freeze ativo"
                                       IsVisible="{Binding HasFrozenEntries}"
                                       Foreground="#79C6F2"
                                       FontWeight="SemiBold"
                                       FontSize="12" />
                                <TextBlock Text="HK"
                                       IsVisible="{Binding HasHotkey}"
                                       Foreground="#F6C86A"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       ToolTip.Tip="{Binding HotkeySummary}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                                <Button Classes="group-action"
                                    Content="Editar Grupo"
                                    Command="{Binding DataContext.EditGroupValuesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Name}"
                                    ToolTip.Tip="Alterar valor de todas as entradas deste grupo" />

                                <Button Classes="group-action"
                                    Content="Inverter Freeze"
                                    Command="{Binding DataContext.ToggleFreezeGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Name}"
                                    ToolTip.Tip="Alternar congelamento para o grupo" />

                                <Button Classes="group-action"
                                    Content="Hotkey"
                                    Command="{Binding DataContext.OpenGroupHotkeyDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Name}"
                                    ToolTip.Tip="Configurar hotkey global para este grupo" />

                                <Button Classes="group-danger"
                                    Content="Remover Grupo"
                                    Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Name}"
                                    ToolTip.Tip="Remove o grupo e todas as entradas dele" />
                                </StackPanel>
                            </Grid>
                            </Border>

                            <Border Classes="group-body-card"
                                Classes.freeze-active="{Binding HasFrozenEntries}"
                                Classes.expanded="{Binding IsExpanded}"
                                IsVisible="{Binding IsExpanded}">
                            <DataGrid Classes="group-grid"
                                  ItemsSource="{Binding Entries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  CanUserSortColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  BorderThickness="0"
                                  SelectionChanged="AddressGrid_OnSelectionChanged"
                                  PointerPressed="AddressGrid_OnPointerPressed"
                                  KeyDown="AddressGrid_OnKeyDown"
                                  DoubleTapped="AddressGrid_OnDoubleTapped">

                                <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="52">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsFrozen, Mode=OneWay}"
                                                                  Command="{Binding DataContext.ToggleFreezeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Descricao"
                                                                Binding="{Binding Description}"
                                                                Width="2.2*"
                                                                MinWidth="240" />

                                            <DataGridTextColumn Header="Endereco"
                                                                Binding="{Binding Address, StringFormat=0x{0:X8}}"
                                                                Width="1.4*"
                                                                MinWidth="170" />

                                            <DataGridTextColumn Header="Valor Atual"
                                                                Binding="{Binding CurrentValue}"
                                                                Width="*"
                                                                MinWidth="150" />

                                            <DataGridTextColumn Header="Tipo"
                                                                Binding="{Binding Type}"
                                                                Width="150"
                                                                MinWidth="130" />
                                    </DataGrid.Columns>

                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Alterar Valor..." Click="EditSelectedValuesMenuItem_OnClick" />
                                            <MenuItem Header="Alterar Descricao..." Click="EditSelectedDescriptionsMenuItem_OnClick" />
                                            <MenuItem Header="Mover para Grupo..." Click="EditSelectedGroupsMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Congelar / Descongelar" Click="ToggleFreezeMenuItem_OnClick" />
                                            <MenuItem Header="Encontrar Ponteiros" Click="FindPointersMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Exportar Cheat Table..." Click="ExportCheatTableMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Excluir" Click="DeleteSelectedMenuItem_OnClick" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.RowSpan="2"
                ZIndex="10"
                Background="#9A000000"
                IsVisible="{Binding IsEditDialogOpen}">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="540"
                    MaxWidth="720"
                    Padding="16"
                    Classes="page-card">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#F0F6FD"
                               Text="{Binding EditDialogTitle}" />
                    <TextBox Text="{Binding EditDialogValue, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Classes="toolbar-secondary"
                                Content="Cancelar"
                                Command="{Binding CloseEditDialogCommand}" />
                        <Button Classes="toolbar-primary"
                                Content="Salvar"
                                Command="{Binding CommitEditDialogCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                ZIndex="11"
                Background="#9A000000"
                IsVisible="{Binding IsGroupPickerOpen}">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="540"
                    MaxWidth="720"
                    Padding="16"
                    Classes="page-card">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#F0F6FD"
                               Text="{Binding GroupPickerTitle}" />
                    <TextBlock Text="Escolha o grupo de destino para a selecao atual."
                               Opacity="0.85"
                               Foreground="#D4E0EC" />
                    <ComboBox ItemsSource="{Binding GroupOptions}"
                              SelectedItem="{Binding SelectedGroupOption, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Classes="toolbar-secondary"
                                Content="Cancelar"
                                Command="{Binding CloseGroupPickerCommand}" />
                        <Button Classes="toolbar-primary"
                                Content="Mover"
                                Command="{Binding CommitGroupPickerCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="3"
                ZIndex="12"
                Background="#9A000000"
                IsVisible="{Binding IsGroupHotkeyDialogOpen}">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="620"
                    MaxWidth="760"
                    Padding="16"
                    Classes="page-card">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#F0F6FD"
                               Text="{Binding GroupHotkeyDialogTitle}" />

                    <CheckBox Content="Ativar hotkey global"
                              IsChecked="{Binding GroupHotkeyEnabled, Mode=TwoWay}" />

                    <Grid ColumnDefinitions="150,*" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="Combinação" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBox Width="280"
                                     IsReadOnly="True"
                                     Text="{Binding GroupHotkeyText, Mode=TwoWay}"
                                     Watermark="Clique em Gravar" />
                            <Button Classes="toolbar-secondary"
                                    Content="Gravar"
                                    Command="{Binding StartGroupHotkeyCaptureCommand}" />
                            <Button Classes="group-danger"
                                    Content="Cancelar"
                                    IsVisible="{Binding IsHotkeyCaptureArmed}"
                                    Command="{Binding CancelGroupHotkeyCaptureCommand}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding GroupHotkeyCaptureHint}"
                               Opacity="0.85"
                               Foreground="#D4E0EC" />

                    <Grid ColumnDefinitions="150,*" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="Ação" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding GroupHotkeyActions}"
                                  SelectedItem="{Binding SelectedGroupHotkeyAction, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnDefinitions="150,*" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="Valor ação" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding GroupHotkeyValue, Mode=TwoWay}"
                                 Watermark="Usado para setar, aumentar ou diminuir" />
                    </Grid>

                    <TextBlock Text="A hotkey é global e funciona mesmo com o jogo em foco."
                               Opacity="0.8"
                               Foreground="#D4E0EC" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Classes="toolbar-secondary"
                                Content="Cancelar"
                                Command="{Binding CloseGroupHotkeyDialogCommand}" />
                        <Button Classes="group-danger"
                                Content="Remover Hotkey"
                                IsVisible="{Binding HasGroupHotkeyInDialog}"
                                Command="{Binding RemoveGroupHotkeyDialogCommand}" />
                        <Button Classes="toolbar-primary"
                                Content="Salvar Hotkey"
                                Command="{Binding SaveGroupHotkeyDialogCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
